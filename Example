-- ──────────────────────────────────────────────
--  Вкладка: Misc
-- ──────────────────────────────────────────────
local Misc = Window:CreateTab("Misc")

Misc:CreateSection("Movement")

Misc:CreateToggle({
    Name         = "Bunny Hop",
    CurrentValue = false,
    Id           = "misc_bhop",
    Callback     = function(v) print("BHop:", v) end
})

Misc:CreateToggle({
    Name         = "Speed Hack",
    CurrentValue = false,
    Id           = "misc_speed",
    Callback     = function(v) print("Speed:", v) end
})

Misc:CreateSlider({
    Name         = "Walk Speed",
    MinValue     = 16,
    MaxValue     = 200,
    CurrentValue = 16,
    Id           = "misc_walkspeed",
    Callback     = function(v)
        local char = game.Players.LocalPlayer.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then hum.WalkSpeed = v end
        end
    end
})

Misc:CreateSlider({
    Name         = "Jump Power",
    MinValue     = 50,
    MaxValue     = 500,
    CurrentValue = 50,
    Id           = "misc_jumppower",
    Callback     = function(v)
        local char = game.Players.LocalPlayer.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then hum.JumpPower = v end
        end
    end
})

Misc:CreateSection("Utilities")

Misc:CreateButton({
    Name     = "Rejoin Server",
    Callback = function()
        game:GetService("TeleportService"):Teleport(game.PlaceId)
    end
})

Misc:CreateButton({
    Name     = "Copy Game ID",
    Callback = function()
        setclipboard(tostring(game.PlaceId))
        Library:Notify({ Title = "Copied!", Content = "Game ID: " .. game.PlaceId })
    end
})

Misc:CreateTextbox({
    Name            = "Custom Tag",
    PlaceholderText = "Enter tag...",
    Callback        = function(v) print("Tag set:", v) end
})

-- Конфиг панель в Misc
Misc:CreateConfigPanel()

