--[[
    BlackWhite UI Library - Example Script
    Загрузка: loadstring(game:HttpGet("URL_TO_LIBRARY"))()
]]

-- Локальная загрузка (если файл рядом):
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/YOUR/REPO/main/Library.lua"))()

-- ──────────────────────────────────────────────
--  Создание окна
-- ──────────────────────────────────────────────
local Window = Library:CreateWindow({
    Title      = "BlackWhite",
    Size       = UDim2.fromOffset(580, 460),
    Executor   = "Solara",           -- Имя исполнителя в ватермарке
    ToggleKey  = Enum.KeyCode.RightShift,  -- Кнопка скрыть/показать UI
})

-- ──────────────────────────────────────────────
--  Вкладка: Legit
-- ──────────────────────────────────────────────
local Legit = Window:CreateTab("Legit")

Legit:CreateSection("Aimbot")

local aimToggle = Legit:CreateToggle({
    Name         = "Enable Aimbot",
    CurrentValue = false,
    Id           = "aimbot_enabled",
    Callback     = function(v)
        print("Aimbot:", v)
    end
})

local fovSlider = Legit:CreateSlider({
    Name         = "FOV",
    MinValue     = 10,
    MaxValue     = 360,
    CurrentValue = 90,
    Suffix       = "°",
    Id           = "aimbot_fov",
    Callback     = function(v)
        print("FOV set to:", v)
    end
})

local smoothSlider = Legit:CreateSlider({
    Name         = "Smoothness",
    MinValue     = 1,
    MaxValue     = 100,
    CurrentValue = 50,
    Suffix       = "%",
    Id           = "aimbot_smooth",
    Callback     = function(v)
        print("Smooth:", v)
    end
})

local aimKey = Legit:CreateKeybind({
    Name     = "Aim Key",
    Default  = Enum.KeyCode.C,
    Id       = "aimbot_key",
    Callback = function(key)
        print("Aim key:", key)
    end
})

Legit:CreateSection("Target")

local targetDrop = Legit:CreateDropdown({
    Name          = "Target Part",
    Options       = { "Head", "Torso", "Random" },
    CurrentOption = "Head",
    Id            = "aimbot_part",
    Callback      = function(v)
        print("Target part:", v)
    end
})

